{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "."
  },
  "include": [
    "core/**/*",
    "tests/**/*",
    "config/**/*",
    "types/**/*",
    "utils/**/*",
    "server/**/*"
  ],
  "ts-node": {
    "transpileOnly": true
  }
}
