# CoderNest QA Core — Environment Configuration
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── API Under Test ────────────────────────────────────────
# Base URL for Supertest requests. No trailing slash.
API_BASE_URL=http://localhost:3000

# ── Authentication ────────────────────────────────────────
# Bearer token injected into all API request headers automatically.
# API_TOKEN=your-api-token-here

# ── Firebase Admin SDK ────────────────────────────────────
# Absolute path to your Firebase service account JSON key file.
# In CI/CD, use a secret to write this file and set the path here.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ── Runtime ───────────────────────────────────────────────
# Options: development | ci | staging | production
NODE_ENV=development
