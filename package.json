{
  "name": "codernest-qa-core",
  "version": "2.0.0",
  "description": "CoderNest QA Core — Professional-grade automated testing engine using TypeScript, Jest, Supertest & Firebase.",
  "main": "core/engine.ts",
  "scripts": {
    "dev": "nodemon --watch server --watch core --ext ts --exec 'ts-node server/server.ts'",
    "build": "tsc --outDir dist",
    "test": "jest --config config/jest.config.ts",
    "test:api": "jest --config config/jest.config.ts --testPathPattern=tests/api",
    "test:int": "jest --config config/jest.config.ts --testPathPattern=tests/integration",
    "test:watch": "jest --config config/jest.config.ts --watch",
    "test:ci": "jest --config config/jest.config.ts --ci --forceExit",
    "engine:run": "ts-node core/engine.ts",
    "start:engine": "ts-node core/engine.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@sparticuz/chromium": "^149.0.0",
    "axios": "^1.17.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "lru-cache": "^11.5.1",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.11",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
